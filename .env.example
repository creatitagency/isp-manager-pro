# Database (Vercel Postgres, Supabase, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:5432/isp_manager?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Resend (Email)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="facturacion@moovitelecom.com"

# Finetwork API
FINETWORK_API_URL="https://api.finetwork.com"
FINETWORK_CLIENT_ID="your-client-id"
FINETWORK_CLIENT_SECRET="your-client-secret"
FINETWORK_OPERATOR_ID="your-operator-id"

# Cron Secret (for Vercel Cron Jobs)
CRON_SECRET="your-cron-secret"

# App
NEXT_PUBLIC_APP_NAME="MooviTelecom"
NEXT_PUBLIC_APP_URL="https://app.moovitelecom.com"